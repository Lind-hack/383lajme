# Pipeline API keys (required for automated news generation)
ANTHROPIC_API_KEY=your_anthropic_key_here
DEEPL_API_KEY=your_deepl_key_here

# Hosted scheduler: Vercel Cron dispatches the GitHub Actions worker.
CRON_SECRET=generate_a_long_random_secret
CODEX_PUSH_TOKEN=github_token_with_actions_workflow_permission

# Ghost CMS (optional — falls back to SQLite pipeline / mock data)
GHOST_URL=https://your-ghost-site.ghost.io
GHOST_CONTENT_API_KEY=your_content_api_key_here
